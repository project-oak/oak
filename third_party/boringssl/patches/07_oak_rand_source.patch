+#include <openssl/rand.h>
+
+#include "../bcm_support.h"
+#include "internal.h"
+
+#if defined(OPENSSL_RAND_OAK)
+
+#include <immintrin.h>
+#include <stdint.h>
+#include <string.h>
+
+// Oak Restricted Kernel runs on x86_64 CPUs with RDRAND support.
+// RDRAND provides a NIST SP 800-90A compliant random number generator
+// built into the CPU.  In a TEE context (AMD SEV-SNP / Intel TDX),
+// RDRAND output is not under host control.
+
+using namespace bssl;
+
+void bssl::CRYPTO_init_sysrand() {}
+
+void bssl::CRYPTO_sysrand(uint8_t *out, size_t requested) {
+  while (requested >= 8) {
+    unsigned long long val;
+    while (!_rdrand64_step(&val)) {
+    }
+    memcpy(out, &val, 8);
+    out += 8;
+    requested -= 8;
+  }
+  if (requested > 0) {
+    unsigned long long val;
+    while (!_rdrand64_step(&val)) {
+    }
+    memcpy(out, &val, requested);
+  }
+}
+
+#endif  // OPENSSL_RAND_OAK
