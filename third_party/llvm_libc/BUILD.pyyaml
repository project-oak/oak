# Build file for the @pyyaml_src archive (the PyYAML source distribution).
#
# The archive is stripped to its `lib/` directory, so the `yaml` (and `_yaml`)
# Python packages sit at the repository root. This filegroup exposes those
# pure-Python sources so //third_party/llvm_libc can stage them onto the
# PYTHONPATH of the LLVM libc CMake build.

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "lib",
    srcs = glob(["**"]),
)
