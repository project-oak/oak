# This is the build file injected into the upstream llvm-project source
# archive (see the `llvm_libc_src` http_archive in //MODULE.bazel). It only
# exposes the archive's files as a filegroup. The Oak-specific overlay files
# are merged in and the actual CMake build is driven from
# //third_party/llvm_libc:BUILD.

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "llvm_libc_srcs",
    srcs = glob(["**"]),
)
