# This is the base docker image we use to bundle example apps like hello world
# enclave apps. We don't build these, we pull them from the existing repo.
#
# rules_oci generates a platform-specific repo with a `_linux_amd64` suffix
# from the `platforms` list. BUILD files should reference the platform-specific
# `@distroless_cc_debian12_linux_amd64` to avoid host-platform matching issues
# when building on macOS (the multi-platform index only resolves for the host).
# See https://github.com/bazel-contrib/rules_oci/blob/main/docs/pull.md
oci.pull(
    name = "distroless_cc_debian12",
    digest = "sha256:6714977f9f02632c31377650c15d89a7efaebf43bab0f37c712c30fc01edb973",
    image = "gcr.io/distroless/cc-debian12",
    platforms = ["linux/amd64"],
)
use_repo(oci, "distroless_cc_debian12", "distroless_cc_debian12_linux_amd64")

