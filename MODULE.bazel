# Repository Symbolic Names
# -------------------------
# These constants represent the different crate indexes used in the project.
STD = "oak_std_crates_index"

NO_STD = "oak_no_std_crates_index"

NO_STD_NO_AVX = "oak_no_std_no_avx_crates_index"

# Repository Groups
# -----------------
# Common combinations of repositories for easier assignment.
ALL_REPOSITORIES = [
    STD,
    NO_STD,
    NO_STD_NO_AVX,
]

ALL_NO_STD = [
    NO_STD,
    NO_STD_NO_AVX,
]

ALL_STD = [STD]

ONLY_NO_STD = [NO_STD]

ONLY_NO_STD_NO_AVX = [NO_STD_NO_AVX]

# Repository Definitions
# ----------------------
# Define the repositories using the collected specifications.

crate.from_specs(
    name = STD,
    supported_platform_triples = [
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "x86_64-unknown-none",
        "wasm32-unknown-unknown",
    ],
)
use_repo(crate, STD)

crate.from_specs(
    name = NO_STD,
    supported_platform_triples = [
        "x86_64-unknown-linux-gnu",
        "x86_64-unknown-none",
        "wasm32-unknown-unknown",
    ],
)
use_repo(crate, NO_STD)

crate.from_specs(
    name = NO_STD_NO_AVX,
    supported_platform_triples = [
        "x86_64-unknown-linux-gnu",
        "x86_64-unknown-none",
        "wasm32-unknown-unknown",
    ],
)
use_repo(crate, NO_STD_NO_AVX)

