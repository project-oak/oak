llvm = use_extension("@toolchains_llvm//toolchain/extensions:llvm.bzl", "llvm", dev_dependency = True)
llvm.toolchain(
    name = "llvm_toolchain",
    # Enable C++ cross-compilation from macOS (aarch64-apple-darwin) to Linux
    # (x86_64-linux).
    #
    # The oak_cc_toolchain_sysroot contains a Debian-based GCC 12 installation.
    # When cross-compiling with clang + --sysroot, clang cannot automatically
    # discover GCC's C++ headers (unlike when running natively on Linux).
    # --gcc-install-dir tells clang exactly where the GCC installation lives
    # within the sysroot, so it can compute the correct -isystem paths for
    # libstdc++ headers.
    #
    # This path is determined by the sysroot layout:
    #   external/+_repo_rules2+oak_cc_toolchain_sysroot/usr/lib/gcc/x86_64-linux-gnu/12
    #
    # Note: toolchains_llvm's builtin-libc++ stdlib is automatically downgraded
    # to stdc++ during cross-compilation (see cc_toolchain_config.bzl:250),
    # so we explicitly set stdlib = "stdc++" to match the sysroot's GCC.
    #
    # TODO: b/490855139 - Full cross-compilation of oak_containers from macOS is
    # blocked by a protobuf exec platform issue: protoc gets compiled as a Linux
    # ELF binary instead of a macOS binary when using --platforms=//:x86_64-linux,
    # causing "cannot execute binary file" errors during proto code generation.
    # This needs to be fixed in the protobuf module's toolchain configuration
    # to properly respect exec vs target platform separation.
    extra_cxx_flags = {
        "linux-x86_64": [
            "--gcc-install-dir=external/+oak_toolchains+oak_cc_toolchain_sysroot/usr/lib/gcc/x86_64-linux-gnu/12",
        ],
    },
    link_flags = {
        "none-x86_64": [
            "-nostdlib",
        ],
    },
    llvm_version = "20.1.0",
    stdlib = {
        "linux-x86_64": "stdc++",
    },
)
llvm.sysroot(
    name = "llvm_toolchain",
    label = "@oak_cc_toolchain_sysroot//:sysroot",
    targets = ["linux-x86_64"],
)
use_repo(llvm, "llvm_toolchain")

register_toolchains(
    "@llvm_toolchain//:all",
    dev_dependency = True,
)

