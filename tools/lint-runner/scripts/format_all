#!/bin/bash

# Feeds oak_lint_runner with all tracked files.
# Detects jj or git and uses the appropriate command.
#
# Usage: format_all

set -o nounset
set -o errexit
set -o pipefail

# --- Build oak_lint_runner via Bazel ---

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"

# Build once; bazel caches so subsequent runs are near-instant.
(cd "${REPO_ROOT}" && bazel build //tools/lint-runner:oak_lint_runner 1>/dev/null)
RUNNER_BIN="${REPO_ROOT}/bazel-bin/tools/lint-runner/oak_lint_runner"

# --- Build file list (try jj, then git) ---

files=$(jj file list 2>/dev/null) \
  || files=$(git ls-files) \
  || {
    echo "Error: not in a jj or git repository." >&2
    exit 1
  }

if [[ -z ${files} ]]; then
  echo "No files to check."
  exit 0
fi

echo "${files}" | "${RUNNER_BIN}"
